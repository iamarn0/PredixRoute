{
  "name": "@predixroute/backend",
  "version": "1.0.0",
  "description": "PredixRoute API Gateway & SaaS Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "concurrently -k -n api,worker -c blue,magenta \"npm:dev:api\" \"npm:dev:worker\"",
    "dev:api": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/jobs/worker.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:worker": "node dist/jobs/worker.js",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration --runInBand",
    "test:coverage": "jest --coverage",
    "seed": "tsx scripts/seed-dev-data.ts"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.3.0",
    "multer": "^2.1.1",
    "nanoid": "^3.3.7",
    "nodemailer": "^8.0.11",
    "rate-limit-redis": "^4.2.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^6.0.2",
    "winston": "^3.13.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.12.0",
    "@types/nodemailer": "^8.0.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "concurrently": "^10.0.3",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.2.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
