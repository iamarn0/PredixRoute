# Backend local development
NODE_ENV=development
PORT=3000
# MongoDB Atlas (or local: mongodb://user:pass@localhost:27017/predixroute?authSource=admin)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/predixroute?retryWrites=true&w=majority&appName=predixroute
REDIS_URL=redis://default:<password>@<host>.db.redis.io:15657
JWT_ACCESS_SECRET=dev_access_secret_min_32_characters_long
JWT_REFRESH_SECRET=dev_refresh_secret_min_32_characters_long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_INTERNAL_TOKEN=dev_internal_token_min_16
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=debug
# Optional: require this secret when registering platform admins (leave empty in local dev)
ADMIN_REGISTRATION_SECRET=

# COD AI Verification (Twilio WhatsApp + OpenAI)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TEMPLATE_SID=
TWILIO_WEBHOOK_BASE_URL=http://localhost:3000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
