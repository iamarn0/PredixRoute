# PredixRoute — production Docker Compose (.env on the server)
# Copy to .env and replace all change_me values before deploying.

# MongoDB (used by docker-compose for the mongodb container)
MONGO_ROOT_USER=predixroute
MONGO_ROOT_PASSWORD=change_me_strong_mongo_password

# If using MongoDB Atlas instead of the container, set MONGODB_URI in docker-compose
# or override backend/worker environment in a custom compose override.

# Redis — container default; for Upstash use redis://:TOKEN@HOST:PORT
REDIS_URL=redis://redis:6379

# JWT — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_access_secret_min_32_characters
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_characters

# Shared secret between backend and AI service
AI_SERVICE_INTERNAL_TOKEN=change_me_internal_token_min_16_chars

# Public URL of your app (IP or domain, no trailing slash)
FRONTEND_URL=http://YOUR_VM_PUBLIC_IP

# Block open admin self-registration in production
ADMIN_REGISTRATION_SECRET=change_me_admin_registration_secret

# Email (optional — without SMTP, emails log to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.com

# COD verification (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_TEMPLATE_SID=
TWILIO_WEBHOOK_BASE_URL=http://YOUR_VM_PUBLIC_IP
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
