# PredixRoute Environment Variables

# MongoDB
MONGO_ROOT_USER=predixroute
MONGO_ROOT_PASSWORD=change_me_in_production
MONGODB_URI=mongodb://predixroute:change_me_in_production@localhost:27017/predixroute?authSource=admin

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AI Service
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_INTERNAL_TOKEN=change_me_internal_token

# AWS
AWS_REGION=ap-south-1
AWS_S3_BUCKET=predixroute-dev-assets
# AWS credentials via IAM role in production

# Email
EMAIL_FROM=noreply@predixroute.com
SENDGRID_API_KEY=

# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=debug

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
